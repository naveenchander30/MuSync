# MuSync 2.0 Environment Configuration

# Base URL for OAuth redirects (change for your deployment)
AUTH_BASE_URL=http://localhost:5001

# Spotify OAuth credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# YouTube OAuth credentials (https://console.cloud.google.com)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/musync

# Master password for encrypting OAuth tokens (change in production!)
MASTER_PASSWORD=change_me_in_production

# Optional: Logging
LOG_LEVEL=INFO

# Optional: Performance tuning
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_PERIOD_SECONDS=60
BATCH_PROCESS_SIZE=20
MAX_CONCURRENT_WORKERS=5

# Optional: Flask
FLASK_ENV=production
PORT=5001
